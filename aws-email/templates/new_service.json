    "Subject": "Nuevo servicio en Buba — {{service_name}}",
    "Html": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<meta name=\"x-apple-disable-message-reformatting\">\n<title>Nuevo servicio en Buba — {{service_name}}</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:wght@400;500;700&display=swap\" rel=\"stylesheet\">\n<!--[if mso]>\n<style type=\"text/css\">\n  body, table, td, a, p, h1, h2 { font-family: Georgia, serif !important; }\n</style>\n<![endif]-->\n</head>\n<body style=\"margin:0; padding:0; background-color:#FAF7F4; font-family:'DM Sans', Helvetica, Arial, sans-serif; color:#2D2D2D;\">\n<center style=\"width:100%; background-color:#FAF7F4;\">\n\n  <!-- Preheader -->\n  <div style=\"display:none; max-height:0; overflow:hidden; font-size:1px; line-height:1px; color:#FAF7F4; mso-hide:all;\">Descubre nuestra última incorporación en Buba Beauty Studio.</div>\n\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#FAF7F4;\">\n    <tr>\n      <td align=\"center\" style=\"padding:24px 16px;\">\n        <table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:600px; width:100%; background-color:#FFFFFF;\">\n\n          <!-- Brand header -->\n          <tr>\n            <td align=\"center\" style=\"padding:28px 24px 20px 24px; border-bottom:1px solid #E8D5C4;\">\n              <p style=\"margin:0; font-family:'Cormorant Garamond', Georgia, serif; font-size:22px; font-weight:500; letter-spacing:4px; color:#1A1A1A;\">BUBA</p>\n              <p style=\"margin:2px 0 0 0; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:9px; letter-spacing:3px; color:#C9A87C; text-transform:uppercase;\">Beauty Studio</p>\n            </td>\n          </tr>\n\n          <!-- Eyebrow -->\n          <tr>\n            <td align=\"center\" style=\"padding:36px 32px 12px 32px;\">\n              <p style=\"margin:0; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:11px; letter-spacing:4px; color:#C9A87C; text-transform:uppercase;\">Nuevo en Buba</p>\n            </td>\n          </tr>\n\n          <!-- Hero image -->\n          <tr>\n            <td style=\"padding:0 32px 0 32px; font-size:0; line-height:0;\">\n              <img src=\"{{service_image_url}}\" alt=\"{{service_name}}\" width=\"536\" style=\"display:block; width:100%; max-width:536px; height:auto; border:0;\">\n            </td>\n          </tr>\n\n          <!-- Service name -->\n          <tr>\n            <td align=\"center\" style=\"padding:32px 32px 8px 32px;\">\n              <h1 style=\"margin:0; font-family:'Cormorant Garamond', Georgia, serif; font-size:40px; font-weight:500; color:#1A1A1A; line-height:1.15;\">{{service_name}}</h1>\n            </td>\n          </tr>\n\n          <!-- Gold divider -->\n          <tr>\n            <td align=\"center\" style=\"padding:16px 32px 24px 32px;\">\n              <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr><td width=\"48\" height=\"1\" style=\"background-color:#C9A87C; font-size:0; line-height:0;\">&nbsp;</td></tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- Description -->\n          <tr>\n            <td style=\"padding:0 48px 24px 48px;\">\n              <p style=\"margin:0; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:16px; line-height:1.7; color:#2D2D2D; text-align:center;\">{{service_description}}</p>\n            </td>\n          </tr>\n\n          <!-- Price -->\n          <tr>\n            <td align=\"center\" style=\"padding:8px 32px 32px 32px;\">\n              <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr>\n                  <td align=\"center\" style=\"padding:12px 32px; background-color:#E8D5C4;\">\n                    <p style=\"margin:0; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:18px; font-weight:700; letter-spacing:2px; color:#1A1A1A;\">{{service_price}}</p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- CTA -->\n          <tr>\n            <td align=\"center\" style=\"padding:0 32px 48px 32px;\">\n              <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr>\n                  <td align=\"center\" bgcolor=\"#C9A87C\" style=\"background-color:#C9A87C;\">\n                    <a href=\"{{cta_url}}\" target=\"_blank\" style=\"display:inline-block; padding:18px 52px; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:14px; font-weight:700; letter-spacing:2px; color:#FFFFFF; text-decoration:none; text-transform:uppercase;\">Reservar ahora</a>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- Divider -->\n          <tr>\n            <td style=\"padding:0 40px;\">\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr><td height=\"1\" style=\"background-color:#E8D5C4; font-size:0; line-height:0;\">&nbsp;</td></tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- Footer -->\n          <tr>\n            <td align=\"center\" style=\"padding:24px 32px 32px 32px;\">\n              <p style=\"margin:0 0 8px 0; font-family:'Cormorant Garamond', Georgia, serif; font-size:18px; color:#1A1A1A;\">Buba Beauty Studio</p>\n              <p style=\"margin:0 0 4px 0; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:13px; line-height:1.6; color:#2D2D2D;\">Rúa Curtis, 8 · 15009 A Coruña</p>\n              <p style=\"margin:0 0 12px 0; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:13px; line-height:1.6; color:#2D2D2D;\">+34 604 028 359</p>\n              <p style=\"margin:0 0 16px 0; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:13px;\">\n                <a href=\"https://www.instagram.com/bubabeautystudio/\" style=\"color:#C9A87C; text-decoration:none;\">Instagram</a>\n              </p>\n              <p style=\"margin:0; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:11px; line-height:1.6; color:#8A8A8A;\">\n                <a href=\"{{amazonSESUnsubscribeUrl}}\" style=\"color:#8A8A8A; text-decoration:underline;\">Cancelar suscripción</a>\n                &nbsp;·&nbsp;\n                <a href=\"{{amazonSESListManagementUrl}}\" style=\"color:#8A8A8A; text-decoration:underline;\">Gestionar preferencias</a>\n              </p>\n            </td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n</center>\n</body>\n</html>\n",
    "Text": "BUBA BEAUTY STUDIO\n==================\n\nNUEVO EN BUBA\n\n{{service_name}}\n\n---\n\n{{service_description}}\n\nPrecio: {{service_price}}\n\nReservar ahora:\n{{cta_url}}\n\n---\n\nBuba Beauty Studio\nRúa Curtis, 8 · 15009 A Coruña\n+34 604 028 359\nInstagram: https://www.instagram.com/bubabeautystudio/\n\nCancelar suscripción: {{amazonSESUnsubscribeUrl}}\nGestionar preferencias: {{amazonSESListManagementUrl}}\n"
  }
